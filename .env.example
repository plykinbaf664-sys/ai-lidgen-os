# Leadgen production limits
LEADGEN_DAILY_LEAD_LIMIT=20
LEADGEN_DISCOVERY_CANDIDATE_BUDGET=1200
LEADGEN_SEARCH_MAX_PAGES=10

# Search transport: browser uses public web result pages and requires no search API key.
# Other supported values: auto, yandex, tavily, yandex_tavily.
LEADGEN_SEARCH_PROVIDER=browser

# Email delivery safety and scheduling
EMAIL_TEST_MODE=
EMAIL_TEST_RECIPIENT=
EMAIL_DAILY_SEND_LIMIT=
EMAIL_BATCH_SEND_LIMIT=
EMAIL_MIN_DELAY_SECONDS=
EMAIL_MAX_DELAY_SECONDS=
FOLLOWUP_ENABLED=true
FOLLOWUP_MIN_INTERVAL_HOURS=24
FOLLOWUP_MAX_PER_LEAD=1
IMAP_HOST=imap.yandex.ru
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASSWORD=
EMAIL_BUSINESS_TIMEZONE=
OUTREACH_PROCESSOR_SECRET=
LEADGEN_BASE_URL=

# SMTP credentials (never commit real values)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
